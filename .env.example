# Copy this file to .env and adjust for production.
# Canonical domain: https://dashboard.aikitz.at
# Secondary UI domain: https://nexora.aikitz.at

# Optional: path to SQLite database (defaults to <state dir>/kitzchat.db)
# KITZCHAT_DB_PATH=./state/kitzchat.db

# Path to KitzChat JSON state files (defaults to ./state)
KITZCHAT_STATE_DIR=./state

# Local workspace runtime root
KITZCHAT_WORKSPACE_ROOT=./state/runtime/default
KITZCHAT_DEFAULT_INSTANCE=default
# Host access lock for dashboard routes/proxy:
# - off: disable host lock
# - comma-separated hostnames: explicit allowlist
KITZCHAT_HOST_LOCK=dashboard.aikitz.at,nexora.aikitz.at

# Multi-instance example (JSON array)
# KITZCHAT_WORKSPACE_INSTANCES=[
#   {"id":"default","label":"Default Workspace","workspaceRoot":"./state/runtime/default"},
#   {"id":"client-a","label":"Client A","workspaceRoot":"./state/runtime/client-a","cronUser":"runner"}
# ]

# Writes back into local runtime files (disabled by default for template safety)
KITZCHAT_ALLOW_POLICY_WRITE=false
KITZCHAT_ALLOW_CRON_WRITE=false
# Writes back into agent workspace files (disabled by default for template safety)
KITZCHAT_ALLOW_WORKSPACE_WRITE=false

# Optional: admin CLI command used by some API routes
# KITZCHAT_ADMIN_CLI=

# Required auth seed credentials (used only when users table is empty)
AUTH_USER=admin
AUTH_PASS=change-me-to-a-long-password

# Required for API key access paths (x-api-key), including Telegram webhook
API_KEY=change-me-to-a-random-secret

# Recommended: dedicated encryption key for customer integration secrets at rest.
# Falls back to API_KEY when unset, but a separate key is preferred for production.
# KITZCHAT_SETTINGS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Optional Stripe billing for customer activation
# STRIPE_SECRET_KEY=sk_live_...
# Optional: pin Stripe API version (recommended)
# STRIPE_API_VERSION=2024-06-20
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

# Canonical public base URL (auth-sensitive flows use this)
PUBLIC_BASE_URL=https://dashboard.aikitz.at
APP_URL=https://dashboard.aikitz.at

# Billing database for live wallet and ledger
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/kitzchat
# MYSQL_HOST=your-mysql-host
# MYSQL_PORT=3306
# MYSQL_DATABASE=your-db
# MYSQL_USER=your-user
# MYSQL_PASSWORD=your-password
# PORT=4100
# STRIPE_SUCCESS_URL=https://dashboard.aikitz.at/usage-token?payment=success&session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=https://dashboard.aikitz.at/usage-token?payment=cancelled
# MIN_TOPUP_EUR=5
# MAX_TOPUP_EUR=500
# CREDIT_MULTIPLIER=1000
# ADMIN_SHARE_RATIO=0.3
# API_BUDGET_RATIO=0.7
# RESERVE_RATIO=0.3
# LOW_BALANCE_THRESHOLD_RATIO=0.2

# Optional OpenAI live usage / billing indicator for the admin overview.
# Leave unset for local-only tracking from chat_usage_events.
# Set this when going live if the admin dashboard should show OpenAI-backed status.
# OPENAI_API_KEY=sk-proj-your-openai-key

# OPENAI_ORG=
# OPENAI_ORG_ID=
# OPENAI_PROJECT=proj_your_project_id

# OpenAI admin key for org endpoints (usage + costs)
# OPENAI_ADMIN_KEY=
# Fixed FX for dashboard display (USD -> EUR)
# OPENAI_USD_TO_EUR=0.92

# Optional OpenAI ChatKit (additive UI surfaces at /internal/chat and /chat)
# Requires OPENAI_API_KEY (or OPENAI_ADMIN_KEY as fallback).
# Each surface can (and should) use its own workflow for isolation.
# OPENAI_CHATKIT_INTERNAL_WORKFLOW_ID=wf_internal_...
# OPENAI_CHATKIT_CUSTOMER_WORKFLOW_ID=wf_customer_...

# Optional cookie security override:
# - false for plain HTTP deployments
# - true for HTTPS-only deployments
AUTH_COOKIE_SECURE=true

# Optional Google OAuth login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Optional: dedicated customer integration OAuth (falls back to login OAuth keys when unset)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# CUSTOMER_INTEGRATION_OAUTH_CALLBACK_URL=https://dashboard.aikitz.at/api/customer/integrations/oauth/callback
# Optional GitHub OAuth for customer integrations
# GITHUB_INTEGRATION_CLIENT_ID=
# GITHUB_INTEGRATION_CLIENT_SECRET=

# Optional Microsoft Graph OAuth for customer integrations (OneDrive)
# MS_OAUTH_CLIENT_ID=
# MS_OAUTH_CLIENT_SECRET=

# Optional Slack OAuth for customer integrations
# SLACK_OAUTH_CLIENT_ID=
# SLACK_OAUTH_CLIENT_SECRET=

# Optional HubSpot OAuth for customer integrations
# HUBSPOT_OAUTH_CLIENT_ID=
# HUBSPOT_OAUTH_CLIENT_SECRET=

# Optional Xero OAuth for customer integrations
# XERO_OAUTH_CLIENT_ID=
# XERO_OAUTH_CLIENT_SECRET=
# Optional restrictions for Google login provisioning
# GOOGLE_AUTH_ALLOWED_EMAILS=alice@example.com,bob@example.com
# GOOGLE_AUTH_ALLOWED_DOMAINS=example.com
# GOOGLE_AUTH_DEFAULT_ROLE=viewer

# Optional integrations (server-only env vars; avoid NEXT_PUBLIC_* for secrets)
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_FROM=
# KITZCHAT_ALERT_EMAILS=ceo@aikitz.at
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# MAILCHIMP_API_KEY=
# HELIUS_URL=
# SANITY_PROJECT_ID=
# SANITY_DATASET=
# SANITY_API_VERSION=2022-11-15
# SANITY_API_TOKEN=

# Optional analytics (server-only)
# Plausible (recommended)
# PLAUSIBLE_BASE_URL=https://plausible.io
# PLAUSIBLE_SITE_ID=example.com
# PLAUSIBLE_API_KEY=
# Optional embedded dashboards (e.g. Plausible shared link, Looker Studio)
# KITZCHAT_ANALYTICS_WEBSITE_IFRAME_URL=
# KITZCHAT_ANALYTICS_SOCIAL_IFRAME_URL=

# Optional local model health probe
# OLLAMA_BASE_URL=http://127.0.0.1:11434


# Google Analytics 4 (server-side via Data API)
# GA4_PROPERTY_ID=123456789
# GA4_SERVICE_ACCOUNT_JSON="{...}"
# Alternatively (base64):
# GA4_SERVICE_ACCOUNT_JSON_B64=

# Social native connectors (optional)
# X_BEARER_TOKEN=
# X_USERNAME=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_ORGANIZATION_URN=urn:li:organization:123
# Optional API version header (yyyyMM)
# LINKEDIN_VERSION=

# Optional 1Password runtime overlay mode for standalone startup:
# - off: never use 1Password
# - auto (default): use 1Password when available, otherwise fallback to existing env
# - required: fail startup if 1Password cannot be used
# KITZCHAT_1PASSWORD_MODE=auto
# Optional path to op:// env template file (used by scripts/start-standalone.sh)
# KITZCHAT_OP_ENV_FILE=/etc/kitzchat/kitzchat.op.env

# Agent metadata defaults:
# - false (default): discover agents dynamically from workspace config/filesystem only
# - true: include built-in static metadata for known IDs (legacy behavior)
# KITZCHAT_USE_DEFAULT_AGENT_META=false
